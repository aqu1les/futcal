---
import { env } from 'cloudflare:workers';
import { eq } from 'drizzle-orm';
import MyTeams from '../components/MyTeams.vue';
import { getDb } from '../db';
import { subscriptions, teams } from '../db/schema';
import Layout from '../layouts/Layout.astro';

export const prerender = false;

const user = Astro.locals.user;

let followed: { id: number; name: string; logo: string | null; country: string | null }[] = [];
if (user) {
  const db = getDb(env);
  followed = await db
    .select({
      id: teams.id,
      name: teams.name,
      logo: teams.logo,
      country: teams.country,
    })
    .from(subscriptions)
    .innerJoin(teams, eq(subscriptions.teamId, teams.id))
    .where(eq(subscriptions.userId, user.id))
    .all();
}

const host = Astro.url.host;
---

<Layout active="teams" title="Meus times · FutCal">
  <section class="pt-6">
    <p class="eyebrow">Minha agenda</p>
    <h1 class="mt-3 font-display text-4xl font-bold text-chalk">Meus times</h1>
  </section>

  <div class="chalk-rule my-8"></div>

  {
    user ? (
      <MyTeams
        client:load
        teams={followed}
        calToken={user.calToken}
        host={host}
      />
    ) : (
      <div class="card p-6 text-center text-chalk-dim">
        Você ainda não segue nenhum time.
        <br />
        <a href="/" class="font-semibold text-flood underline">
          Buscar um time
        </a>
      </div>
    )
  }
</Layout>
