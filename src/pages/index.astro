---
import TeamSearch from '../components/TeamSearch.vue';
import Layout from '../layouts/Layout.astro';
---

<Layout active="home">
  <section class="pt-6">
    <p class="eyebrow">Escalação</p>
    <h1
      class="mt-3 font-display text-4xl leading-[1.05] font-bold text-chalk sm:text-5xl"
    >
      Os jogos do seu time,<br />direto no seu calendário.
    </h1>
    <p class="mt-4 max-w-md text-chalk-dim">
      Escolha os times, copie o link e assine no Google ou Apple Calendar. A
      gente sincroniza os jogos todo dia — você nunca perde um.
    </p>
  </section>

  <div class="chalk-rule my-8"></div>

  <section>
    <p class="eyebrow mb-4">Seguir um time</p>
    <TeamSearch client:load />
  </section>
</Layout>
